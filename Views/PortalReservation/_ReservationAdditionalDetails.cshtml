@model Portal.ViewModels.ReservationFormViewModel

@{
    var hasItem = Model.Item?.PortalItem != null;
    var hasPrices = Model.Item?.PortalItem?.PortalItemPrices?.Any() ?? false;
    var dayPrice = Model.Item?.PortalItem?.PortalItemPrices?.FirstOrDefault(p => p.BaseUnit == "Day");
    var basePrice = dayPrice?.BasePrice ?? 0;
    var baseCurrency = (dayPrice?.BaseCurrency ?? "PHP").Trim().Replace("\t", "");

}

<div class="mb-4">
    <h5 class="mb-3">Reservation Details</h5>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="ReservationAdditionalInfo.PickupLocation" class="form-label">Pickup Location</label>
            <select asp-for="ReservationAdditionalInfo.PickupLocation" class="form-select">
                <option value="">-- Select Pickup Location --</option>
                <option value="Airport">Airport</option>
                <option value="Hotel">Hotel</option>
                <option value="Within downtown area">Within downtown area</option>
                <option value="Others (Outside Downtown/Outside the City)">Others (Outside Downtown/Outside the City)</option>
            </select>
            <span asp-validation-for="ReservationAdditionalInfo.PickupLocation" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="ReservationAdditionalInfo.PickupInfo" class="form-label">Pickup Info</label>
            <input asp-for="ReservationAdditionalInfo.PickupInfo" class="form-control" placeholder="Enter pickup info" />
            <span asp-validation-for="ReservationAdditionalInfo.PickupInfo" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="ReservationAdditionalInfo.PickupDate" class="form-label">Pickup Date</label>
            <input asp-for="ReservationAdditionalInfo.PickupDate" type="date" class="form-control" />
            <span asp-validation-for="ReservationAdditionalInfo.PickupDate" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="ReservationAdditionalInfo.PickupTime" class="form-label">Pickup Time</label>
            <input asp-for="ReservationAdditionalInfo.PickupTime" type="time" class="form-control" />
            <span asp-validation-for="ReservationAdditionalInfo.PickupTime" class="text-danger"></span>
        </div>
    </div>


    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="ReservationAdditionalInfo.DestinationArea" class="form-label">Destination</label>
            <select asp-for="ReservationAdditionalInfo.DestinationArea" class="form-select">
                <option value="">-- Select Destination Area --</option>
                <option value="Downtown">Downtown</option>
                <option value="Davao Country Side">Davao Country Side</option>
                <option value="Davao Marilog and Buda">Davao Marilog and Buda</option>
                <option value="Out of Town">Out of Town</option>
            </select>
            <span asp-validation-for="ReservationAdditionalInfo.DestinationArea" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="ReservationAdditionalInfo.DestinationInfo" class="form-label">Destination Info</label>
            <input asp-for="ReservationAdditionalInfo.DestinationInfo" class="form-control" placeholder="Enter destination info" />
            <span asp-validation-for="ReservationAdditionalInfo.DestinationInfo" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="ReservationAdditionalInfo.NumberOfDays" class="form-label">Number of Days</label>
            <input asp-for="ReservationAdditionalInfo.NumberOfDays" type="number" min="1" class="form-control" placeholder="Enter number of days" id="numberOfDays" />
            <span asp-validation-for="ReservationAdditionalInfo.NumberOfDays" class="text-danger"></span>
        </div>
    </div>


    @if (Model.Item?.PortalItem != null && basePrice > 0)
    {
        <div class="row">
            <div class="col-12 mb-3">
                <div class="alert alert-info">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <strong>Estimated Total Cost:</strong>
                            <span id="estimatedCost" class="fs-5 text-primary">@baseCurrency 0.00</span>
                        </div>
                        <small class="text-muted">Base Rate: @basePrice.ToString("N2") @baseCurrency / Day</small>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<script>
   
    (function() {

        const basePrice = @basePrice;
        const currency = '@Html.Raw(baseCurrency)';
        const numberOfDaysInput = document.getElementById('numberOfDays');
        const estimatedCostDisplay = document.getElementById('estimatedCost');
        let totalCost = 0.00;

        // Function to calculate and display the estimated cost
        function calculateEstimatedCost() {
            const numberOfDays = parseInt(numberOfDaysInput.value) || 0;
            totalCost = basePrice * numberOfDays;

            if (estimatedCostDisplay) {
                const formattedCost = totalCost.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
                estimatedCostDisplay.textContent = currency + ' ' + formattedCost;
            }
        }

        // Add event listeners to recalculate the estimated cost when the number of days changes
        if (numberOfDaysInput) {
            numberOfDaysInput.addEventListener('input', calculateEstimatedCost);
            numberOfDaysInput.addEventListener('change', calculateEstimatedCost);

            // Calculate on page load if there's already a value
            if (numberOfDaysInput.value) {
                calculateEstimatedCost();
            }
        }


    // Serialize reservation additional details to JSON on form submission
        // Get the form element
        const form = document.getElementById('reservationForm');

        if (form) {
            form.addEventListener('submit', function(e) {
                // Get the additional details field values
                const pickupLocationInput = document.getElementById('@Html.IdFor(m => m.ReservationAdditionalInfo.PickupLocation)');
                const pickupInfoInput = document.getElementById('@Html.IdFor(m => m.ReservationAdditionalInfo.PickupInfo)');
                const pickupDateInput = document.getElementById('@Html.IdFor(m => m.ReservationAdditionalInfo.PickupDate)');
                const pickupTimeInput = document.getElementById('@Html.IdFor(m => m.ReservationAdditionalInfo.PickupTime)');
                const destinationAreaInput = document.getElementById('@Html.IdFor(m => m.ReservationAdditionalInfo.DestinationArea)');
                const destinationInfoInput = document.getElementById('@Html.IdFor(m => m.ReservationAdditionalInfo.DestinationInfo)');
                // const numberOfDaysInput = document.getElementById('@Html.IdFor(m => m.ReservationAdditionalInfo.NumberOfDays)');
                const numberOfDaysInput = document.getElementById('numberOfDays');
                const jsonDataInput = document.getElementById('@Html.IdFor(m => m.Reservation.JsonData)');
                
                // Calculate the estimated cost based on the number of days and base price
                const numberOfDays = parseInt(numberOfDaysInput.value) || 0;
                // const totalCost = basePrice * numberOfDays;


                // Create JSON object with the additional details
                const additionalDetails = {
                    PickupLocation: pickupLocationInput?.value || null,
                    PickupInfo: pickupInfoInput?.value || null,
                    PickupDate: pickupDateInput?.value || null,
                    PickupTime: pickupTimeInput?.value || null,
                    DestinationArea: destinationAreaInput?.value || null,
                    DestinationInfo: destinationInfoInput?.value || null,
                    NumberOfDays: numberOfDaysInput?.value ? parseInt(numberOfDaysInput.value) : null,
                    CalculatedCost: totalCost,
                    BaseRate: basePrice,
                    BaseCurrency: currency
                };

                // Serialize to JSON and set the hidden field value
                if (jsonDataInput) {
                    jsonDataInput.value = JSON.stringify(additionalDetails);
                }
            });
        }
    })();
</script>
