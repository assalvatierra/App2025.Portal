@model IEnumerable<Portal.Models.ItemDto>

@{
    ViewData["Title"] = "Search Results";
    var searchTerm = ViewBag.SearchTerm as string;
    var compareList = ViewBag.CompareList as List<int> ?? new List<int>();
}

@* Include the Compare Toast Component *@
@await Html.PartialAsync("_CompareToast")

<div class="container my-5">
    <div class="row">
        <div class="col-md-12">
            <h1 class="mb-4">@ViewBag.PageTitle</h1>

            @if (!string.IsNullOrWhiteSpace(ViewBag.PageMessage as string))
            {
                <p class="lead">@ViewBag.PageMessage</p>
            }

            <!-- Back to Search Button -->
            <div class="mb-3">
                <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back to Home
                </a>
            </div>

            @if (Model != null && Model.Any())
            {
                <div class="alert alert-success" role="alert">
                    Found @Model.Count() item(s)
                </div>

                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                    @foreach (var item in Model)
                    {
                        @await Html.PartialAsync("_ItemCard", (item, compareList, showActions: true, cardMode: ViewBag.cardMode as string, transactionType: ViewBag.TransactionType as string))
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info" role="alert">
                    <h4 class="alert-heading">No Results Found</h4>
                    <p>No items matched your search criteria. Please try a different search term.</p>
                    <hr>
                    <p class="mb-0">
                        <a asp-controller="Home" asp-action="Index" class="alert-link">Try another search</a>
                    </p>
                </div>
            }
        </div>
    </div>
</div>

<!-- Additional styles for better card presentation -->
<style>
    .card {
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 4px 15px rgba(0,0,0,0.2) !important;
    }

    .card-title {
        color: #2c3e50;
        font-weight: 600;
    }

    .badge {
        font-size: 0.75rem;
        padding: 0.35em 0.65em;
    }

    .add-to-compare-btn.added {
        background-color: #28a745;
        color: white;
        border-color: #28a745;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Handle Add to Compare button click
            $('.add-to-compare-btn').on('click', function () {
                var button = $(this);
                var itemId = button.data('item-id');
                var itemName = button.data('item-name');

                // Disable button during request
                button.prop('disabled', true);

                $.ajax({
                    url: '@Url.Action("AddToCompare", "Home")',
                    type: 'POST',
                    data: { itemId: itemId },
                    success: function (response) {
                        if (response.success) {
                            // Replace with Remove button
                            var removeBtn = $('<button type="button" class="btn btn-sm btn-outline-danger remove-from-compare-btn" data-item-id="' + itemId + '" data-item-name="' + itemName + '"><i class="bi bi-x-circle"></i> Remove from Compare</button>');
                            button.replaceWith(removeBtn);

                            // Attach event handler to new button
                            attachRemoveHandler(removeBtn);

                            // Show success message
                            showToast('success', response.message || itemName + ' added to comparison list');

                            // Update the compare toast notification
                            if (typeof checkCompareItems === 'function') {
                                checkCompareItems();
                            }
                        } else {
                            // Show error message
                            showToast('error', response.message || 'Failed to add item to comparison');
                            button.prop('disabled', false);
                        }
                    },
                    error: function (xhr, status, error) {
                        showToast('error', 'An error occurred. Please try again.');
                        button.prop('disabled', false);
                    }
                });
            });

            // Handle Remove from Compare button click
            function attachRemoveHandler(button) {
                button.on('click', function () {
                    var btn = $(this);
                    var itemId = btn.data('item-id');
                    var itemName = btn.data('item-name');

                    // Disable button during request
                    btn.prop('disabled', true);

                    $.ajax({
                        url: '@Url.Action("RemoveFromCompare", "Home")',
                        type: 'POST',
                        data: { itemId: itemId },
                        success: function (response) {
                            if (response.success) {
                                // Replace with Add button
                                var addBtn = $('<button type="button" class="btn btn-sm btn-outline-info add-to-compare-btn" data-item-id="' + itemId + '" data-item-name="' + itemName + '"><i class="bi bi-clipboard-check"></i> Add to Compare</button>');
                                btn.replaceWith(addBtn);

                                // Attach event handler to new button
                                addBtn.on('click', function() {
                                    $(this).trigger('click');
                                });

                                // Show success message
                                showToast('success', response.message || itemName + ' removed from comparison list');

                                // Update the compare toast notification
                                if (typeof checkCompareItems === 'function') {
                                    checkCompareItems();
                                }
                            } else {
                                // Show error message
                                showToast('error', response.message || 'Failed to remove item from comparison');
                                btn.prop('disabled', false);
                            }
                        },
                        error: function (xhr, status, error) {
                            showToast('error', 'An error occurred. Please try again.');
                            btn.prop('disabled', false);
                        }
                    });
                });
            }

            // Attach remove handler to existing remove buttons on page load
            $('.remove-from-compare-btn').each(function() {
                attachRemoveHandler($(this));
            });

            // Toast notification function
            function showToast(type, message) {
                var toastClass = type === 'success' ? 'bg-success' : 'bg-danger';
                var toastHtml = `
                    <div class="toast align-items-center text-white ${toastClass} border-0" role="alert" aria-live="assertive" aria-atomic="true">
                        <div class="d-flex">
                            <div class="toast-body">
                                ${message}
                            </div>
                            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                        </div>
                    </div>
                `;

                // Create toast container if it doesn't exist
                if ($('#toastContainer').length === 0) {
                    $('body').append('<div id="toastContainer" class="toast-container position-fixed bottom-0 end-0 p-3"></div>');
                }

                var toastElement = $(toastHtml);
                $('#toastContainer').append(toastElement);

                var toast = new bootstrap.Toast(toastElement[0], {
                    autohide: true,
                    delay: 3000
                });
                toast.show();

                // Remove toast element after it's hidden
                toastElement.on('hidden.bs.toast', function () {
                    $(this).remove();
                });
            }
        });
    </script>
}
